# Supabase (Production) — used by default
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# Supabase (Staging) — used when running `npm run start:staging`
REACT_APP_STAGING_SUPABASE_URL=https://your-staging-project.supabase.co
REACT_APP_STAGING_SUPABASE_ANON_KEY=your_staging_anon_key
